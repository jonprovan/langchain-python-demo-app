# AWS credentials are picked up via the standard IAM credential chain
# (environment variables, shared config/credentials file, SSO profile, or role).
# Set AWS_PROFILE if you use a named profile instead of default/env-var credentials.
# AWS_PROFILE=my-profile

AWS_REGION=us-east-1

# Chat/generation model used for answer generation, document grading, and query rewriting.
# Default is the Claude Haiku 4.5 cross-region inference profile.
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# Titan Text Embeddings V2 dimension used by the Knowledge Base vector index.
# Must match scripts/provision_kb.py exactly.
EMBEDDING_MODEL_DIMENSION=1024

# Filled in after running scripts/provision_kb.py.
KNOWLEDGE_BASE_ID=
DATA_SOURCE_ID=

# S3 bucket used as the Knowledge Base data source (created by scripts/provision_kb.py).
KB_DATA_BUCKET=

# LangSmith tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=langchain-demo-app

FLASK_SECRET_KEY=dev-secret-change-me
